# ════════════════════════════════════════════════════════════
#  AitoTech — Environment Variables
#  Copy this file to .env.local and fill in your values.
# ════════════════════════════════════════════════════════════

# ─── Supabase (database, auth, admin panel, CMS) ───
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Service-role key — SECRET. Used only on the server. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── SEO / canonical URLs (set on Vercel production) ───
NEXT_PUBLIC_SITE_URL=https://aitotech.in

# ─── Routely launch page (/routely) — "Try in browser" link ───
NEXT_PUBLIC_ROUTELY_APP_URL=https://app.routely.aitotech.in
# Google Search Console HTML tag verification (optional)
# GOOGLE_SITE_VERIFICATION=your_google_verification_code

# ─── Routely demo (/routely/demo) ───
# Default: FREE mock demo (no OpenRouter cost). Do NOT set AKSH_DEMO_LIVE unless you want paid live AI.
# AKSH_DEMO_LIVE=true
# AKSH_API_URL=https://api.routely.aitotech.in
# AKSH_API_KEY=

# ─── Separate Aitotech-agents project (contact form → /tasks) ───
# AGENTS_API_URL=https://your-other-agents.up.railway.app
# AGENTS_API_KEY=

# ─── Contact form email notifications (OPTIONAL) ───
# Leads are always saved to Supabase. These only add an email alert on top.

# Formspree: https://formspree.io — create a form and paste the endpoint URL
# FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# OR EmailJS (server-side): https://www.emailjs.com/docs/rest-api/send/
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_PUBLIC_KEY=your_public_key
# EMAILJS_PRIVATE_KEY=your_private_key
