# Production env for Docker on E2E (copy to .env on server)

# Public site URL (after DNS + HTTPS)
NEXT_PUBLIC_SITE_URL=https://aitotech.in

# Routely browser app (Vercel static or Railway /web/browser)
NEXT_PUBLIC_ROUTELY_APP_URL=https://app.routely.aitotech.in

# Supabase — same project as before (waitlist + admin + leads)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional SEO
# GOOGLE_SITE_VERIFICATION=

# Optional — Aksh live demo on /aksh (Vercel uses AKSH_API_URL)
# AKSH_API_URL=https://aitotech-neuralrouter-production.up.railway.app
# AKSH_API_KEY=

# Optional — separate agents project (contact form)
# AGENTS_API_URL=
# AGENTS_API_KEY=

# Docker port on VM (nginx proxies 443 → this port)
WEBSITE_HTTP_PORT=3000
